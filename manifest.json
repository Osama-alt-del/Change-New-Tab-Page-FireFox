{
    "manifest_version": 2,
    "name": "New Tab Page Changer",
    "version": "1.0",

    "description": "This is an extension that lets you change the new tab page on FireFox",

    "icons":{
        "48": "icons/NewTabIcon.png"
    },

    "browser_specific_settings": {
        "gecko":{
            "data_collection_permissions":{
                "required": ["none"]
            }
        }
    },

    "chrome_url_overrides":{
        "newtab": "redirect.html"
    }
}
